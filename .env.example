# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# VERCEL / ENVIRONMENT OVERRIDES CONFIGURATION
# ==========================================
# If deployed on Vercel or other serverless read-only platforms,
# you can use these environment variables to configure and persist your settings permanently.

# 1. Admin Credentials Override (Default username: okkhor, Default password: pathagar)
ADMIN_USERNAME="okkhor"
ADMIN_PASSWORD="your_custom_password"

# 2. Firebase Configuration Override (If using Firebase Authentication and Firestore)
FIREBASE_API_KEY="AIzaSy..."
FIREBASE_AUTH_DOMAIN="your-app.firebaseapp.com"
FIREBASE_PROJECT_ID="your-app"
FIREBASE_STORAGE_BUCKET="your-app.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789"
FIREBASE_APP_ID="1:123456789:web:abcd1234"

# 3. Google Sheets Integration Override
GOOGLE_SHEETS_WEB_APP_URL="https://script.google.com/macros/s/.../exec"
GOOGLE_SHEETS_AUTO_SYNC="true"

# 4. SMS Gateway Override (Optional)
SMS_PROVIDER="bulksmsbd" # "simulated" or "bulksmsbd"
SMS_API_KEY="your_bulksmsbd_api_key"
SMS_SENDER_ID="88017XXXXXXXX"

# 5. Database Configuration
DB_HOST="localhost"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="librery"
DB_PORT="3306"
